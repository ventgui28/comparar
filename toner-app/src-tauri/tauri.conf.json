{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Comparador Toners",
  "version": "0.1.0",
  "identifier": "pt.comparacaotinteiros.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "🖨️ Comparador de Toners e Tinteiros",
        "width": 1200,
        "height": 750,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "maximized": false,
        "center": true,
        "decorations": true,
        "transparent": false,
        "shadow": true,
        "alwaysOnTop": false,
        "visible": true,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Comparação Tinteiros",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": "pt-PT",
        "bannerPath": "wix/banner.bmp",
        "dialogImagePath": "wix/dialog.bmp"
      }
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}